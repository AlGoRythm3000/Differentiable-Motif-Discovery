full_environment.yml

# ignore Python bytecode files and cache directories
__pycache__/
.pytest_cache/
*.pyc
models/__pycache__/
tasks/__pycache__/
tests/__pycache__/
tools/__pycache__/

# ignore virtual environment directories
venv/
*.egg-info/

# ignore downloaded/cached datasets (auto-fetched by TUDataset etc.)
datasets/

# ignore per-run training results (config/metrics/graph snapshots) - keep
# results/analyze_results.py tracked, just not its output.
results/runs/

CLAUDE.md
